# Copy to `.env` and fill in your own keys. `.env` is git-ignored.
# Load before running, e.g.:
#     export $(grep -v '^#' .env | xargs)

# Google Gemini — comma-separated list, rotated round-robin across calls
GEMINI_API_KEYS=key1,key2,key3

# Anthropic Claude (used by claude_ceiling_test.py)
ANTHROPIC_API_KEY=sk-ant-...

# Local Ollama server for Qwen (used by qwen_predict.py).
# Default is http://localhost:11434/v1 — only override if Ollama runs elsewhere.
OLLAMA_BASE_URL=http://localhost:11434/v1
